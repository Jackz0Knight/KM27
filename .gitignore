# ---- Godot 4.x ----
# Editor & import cache (Godot 4 stores per-resource .import metadata in .godot/)
.godot/
# Translations compiled artifact
*.translation
# Common export output folders
/android/
/build/
/dist/
# Local export overrides (export.cfg can hold credentials; export_presets.cfg
# is intentionally tracked per Godot convention — audit it before committing).
export.cfg
# NOTE: do NOT ignore *.import or *.uid files — Godot 4 requires both
# tracked (Godot 4.4+ writes a .uid for every script as a stable id).

# ---- OS ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Editors / IDEs ----
.vscode/
.idea/
# Claude Code: shared project settings (SessionStart hook fetches headless
# Godot for cloud sessions) are tracked; everything else in .claude/ stays
# local (settings.local.json holds machine-specific binary whitelists).
.claude/*
!.claude/settings.json
*.swp
*.swo
*~

# ---- Misc ----
*.tmp
*.bak
*.log
.env
.env.local
