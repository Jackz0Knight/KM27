root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Godot conventions (tabs for GDScript and scene/resource files)
[*.{gd,tscn,tres,godot}]
indent_style = tab

# Markdown: 2-space indent, keep trailing whitespace (used for hard line breaks)
[*.md]
indent_size = 2
trim_trailing_whitespace = false
